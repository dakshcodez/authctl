APP_ENV=development
LOG_LEVEL=info

# Path to the SQLite database file.
# For Docker: must be inside /home/authctl/.authctl/ (the named volume mount).
# For local builds: defaults to ~/.authctl/authctl.db — omit this line to use the default.
DB_PATH=/home/authctl/.authctl/authctl.db

# Session validity duration
SESSION_TIMEOUT=24h

# Account lockout settings
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=15m

# bcrypt work factor — 12 is the minimum recommended for production
BCRYPT_COST=12

# Required for MFA. Generate with: openssl rand -hex 32
# Keep this secret — losing it makes all stored TOTP secrets unrecoverable.
TOTP_ENCRYPTION_KEY=